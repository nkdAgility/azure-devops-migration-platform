{
    "version": "0.2.0",
    "configurations": [
        // ── Migration CLI: configure ──────────────────────────────────────────
        // Options: [-o|--output] [-f|--force] [-c|--config] [-v|--verbose]
        //          [--disable-telemetry] [--dry-run]
        {
            "name": "🔧 Migration CLI: Configure",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "configure"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        {
            "name": "🔧 Migration CLI: Configure (Custom Output)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "configure",
                "--output",
                "migration.json"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        {
            "name": "🔧 Migration CLI: Configure (Force Overwrite)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "configure",
                "--output",
                "migration.json",
                "--force"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        // ── Migration CLI: discovery inventory ────────────────────────────────
        // Options: [--output <PATH>] [-c|--config] [-v|--verbose]
        //          [--disable-telemetry] [--dry-run]
        {
            "name": "🔍 Migration CLI: Inventory (Config File)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "discovery",
                "inventory",
                "--config",
                "migration.json"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        {
            "name": "🔍 Migration CLI: Inventory (Config + Output Path)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "discovery",
                "inventory",
                "--config",
                "migration.json",
                "--output",
                "./inventory-results"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        {
            "name": "🔍 Migration CLI: Inventory (Verbose)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "discovery",
                "inventory",
                "--config",
                "migration.json",
                "--verbose"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        {
            "name": "🔍 Migration CLI: Inventory (Dry Run)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "discovery",
                "inventory",
                "--config",
                "migration.json",
                "--dry-run"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        // ── Migration CLI: tfsexport ──────────────────────────────────────────
        // Options: --collection <URL> --project <NAME> [--output <PATH>]
        //          [--tfsexport-path <PATH>]
        {
            "name": "📦 Migration CLI: TFS Export",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "tfsexport",
                "--collection",
                "http://tfs:8080/tfs/DefaultCollection",
                "--project",
                "MyProject",
                "--output",
                "./test-package"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        {
            "name": "📦 Migration CLI: TFS Export (Custom Exe Path)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "tfsexport",
                "--collection",
                "http://tfs:8080/tfs/DefaultCollection",
                "--project",
                "MyProject",
                "--output",
                "./test-package",
                "--tfsexport-path",
                "./src/DevOpsMigrationPlatform.CLI.TfsMigration/bin/Debug/net481/tfsmigration.exe"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        // ── Migration CLI: logs ───────────────────────────────────────────────
        // Options: --job <GUID> [--follow]
        {
            "name": "📋 Migration CLI: Logs (Job ID)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "logs",
                "--job",
                "00000000-0000-0000-0000-000000000001"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        {
            "name": "📋 Migration CLI: Logs (Follow)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.Migration/bin/Debug/net10.0/devopsmigration.exe",
            "args": [
                "logs",
                "--job",
                "00000000-0000-0000-0000-000000000001",
                "--follow"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-migration-cli"
        },
        // ── TFS CLI (net481): export & inventory ──────────────────────────────
        // export:    --collection <URL> --project <NAME> [--output <PATH>]
        // inventory: --collection <URL> (--project <NAME> | --all-projects)
        {
            "name": "🔴 TFS CLI: Export",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.TfsMigration/bin/Debug/net481/tfsmigration.exe",
            "args": [
                "export",
                "--collection",
                "http://tfs:8080/tfs/DefaultCollection",
                "--project",
                "MyProject",
                "--output",
                "./test-tfs-package"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-tfs-cli"
        },
        {
            "name": "🔴 TFS CLI: Inventory (All Projects)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.TfsMigration/bin/Debug/net481/tfsmigration.exe",
            "args": [
                "inventory",
                "--collection",
                "http://tfs:8080/tfs/DefaultCollection",
                "--all-projects"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-tfs-cli"
        },
        {
            "name": "🔴 TFS CLI: Inventory (Single Project)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DevOpsMigrationPlatform.CLI.TfsMigration/bin/Debug/net481/tfsmigration.exe",
            "args": [
                "inventory",
                "--collection",
                "http://tfs:8080/tfs/DefaultCollection",
                "--project",
                "MyProject"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build-tfs-cli"
        }
    ]
}