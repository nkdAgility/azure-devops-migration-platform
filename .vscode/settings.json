{
    // Project-specific VS Code settings for Azure DevOps Migration Platform
    
    // .NET and C# settings for this project
    "dotnet.completion.showCompletionItemsFromUnimportedNamespaces": true,
    "dotnet.enablePackageRestore": true,

    
    // File associations for this project
    "files.associations": {
        "*.feature": "gherkin",
        "migration.json": "jsonc",
        "test-*.json": "jsonc",
        "dev-*.json": "jsonc"
    },
    
    // Testing settings for this solution
    "dotnet.unitTests.runSettingsPath": "",
    "dotnet.unitTests.discoverAllTestsTimeout": 60,
    
    // Search settings to exclude build outputs and test artifacts
    "search.exclude": {
        "**/bin": true,
        "**/obj": true,
        "**/node_modules": true,
        "**/.vs": true,
        "**/test-*": true,
        "**/test-output": true,
        "**/test-package": true,
        "**/migration-output": true
    },
    
    // File watcher exclusions for better performance
    "files.watcherExclude": {
        "**/bin/**": true,
        "**/obj/**": true,
        "**/node_modules/**": true,
        "**/.vs/**": true,
        "**/test-output/**": true,
        "**/test-package/**": true,
        "**/migration-output/**": true
    },
    
    // Language specific settings for consistent formatting
    "[csharp]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-dotnettools.csharp"
    },
    "[json]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.formatOnSave": true
    },
    "[jsonc]": {
        "editor.tabSize": 2,  
        "editor.insertSpaces": true,
        "editor.formatOnSave": true
    },
    "[gherkin]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },
    
    // Copilot chat prompt file recommendations for SpecKit agents
    "chat.promptFilesRecommendations": {
        "speckit.constitution": true,
        "speckit.specify": true,
        "speckit.plan": true,
        "speckit.tasks": true,
        "speckit.implement": true
    },

    // Auto-approve terminal commands for SpecKit scripts
    "chat.tools.terminal.autoApprove": {
        ".specify/scripts/bash/": true,
        ".specify/scripts/powershell/": true
    },

    // JSON schema mappings for migration configuration files
    "json.schemas": [
        {
            "fileMatch": [
                "**/migration*.json",
                "**/migration-config.json",
                "**/scenarios/**/*.json"
            ],
            "url": "./src/DevOpsMigrationPlatform.CLI.Migration/migration.schema.json"
        }
    ]
}