{
  "MigrationPlatform": {
    "ConfigVersion": "1.0",
    "Policies": {
      "Retries": {
        "Max": 3
      },
      "Throttle": {
        "MaxConcurrency": 1
      },
      "Checkpoints": {
        "Interval": 300
      }
    },
    "Mode": "Import",
    "Target": {
      "Type": "Simulated",
      "Url": "https://dev.azure.com/simulated",
      "Project": "SimulatedTarget"
    },
    "Package": {
      "WorkingDirectory": "%DEVOPS_MIGRATION_TEST_STORAGE%",
      "CreatePackage": true,
      "PackagePath": "scenarios\\testdata\\workitems-2items-flat.zip"
    },
    "Modules": {
      "WorkItems": {
        "Enabled": true,
        "Extensions": {
          "WorkItemResolutionStrategy": {
            "Strategy": ""
          },
          "Revisions": {
            "Enabled": true
          },
          "Links": {
            "Enabled": true
          },
          "Attachments": {
            "Enabled": true
          },
          "Comments": {
            "Enabled": true
          },
          "EmbeddedImages": {
            "Enabled": true
          }
        }
      }
    }
  }
}