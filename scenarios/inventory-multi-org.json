{
  "MigrationPlatform": {
    "ConfigVersion": "1.0",
    "Policies": {
      "Retries": {
        "Max": 8
      },
      "Throttle": {
        "MaxConcurrency": 4
      },
      "Checkpoints": {
        "Interval": 300
      }
    },
    "Organisations": [
      {
        "Type": "AzureDevOpsServices",
        "Url": "$ENV:AZDEVOPS_DEV_ORG",
        "Projects": [],
        "Authentication": {
          "Type": "Pat",
          "AccessToken": "$ENV:AZDEVOPS_DEV_PAT"
        }
      },
      {
        "Type": "AzureDevOpsServices",
        "Url": "https://dev.azure.com/nkdagility-learn/",
        "Projects": [],
        "Authentication": {
          "Type": "Pat",
          "AccessToken": "$ENV:AZDEVOPS_DEV_PAT"
        }
      }
    ],
    "Package": {
      "WorkingDirectory": "%DEVOPS_MIGRATION_TEST_STORAGE%"
    }
  }
}