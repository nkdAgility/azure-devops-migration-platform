{
  "MigrationPlatform": {
    "ConfigVersion": "2.0",
    "Mode": "Dependencies",
    "Policies": {
      "Retries": {
        "Max": 8
      },
      "Throttle": {
        "MaxConcurrency": 4
      },
      "Checkpoints": {
        "Interval": 300
      }
    },
    "Organisations": [
      {
        "Type": "AzureDevOpsServices",
        "Url": "$ENV:AZDEVOPS_SYSTEM_TEST_ORG",
        "Projects": [
          "migrationTest5"
        ],
        "Authentication": {
          "Type": "AccessToken",
          "AccessToken": "$ENV:AZDEVOPS_SYSTEM_TEST_PAT"
        }
      }
    ],
    "Package": {
      "WorkingDirectory": "%DEVOPS_MIGRATION_TEST_STORAGE%"
    }
  }
}
