{
  "ConfigVersion": "1.0",
  "Mode": "Export",
  "Source": {
    "Type": "AzureDevOpsServices",
    "Url": "$ENV:AZDEVOPS_DEV_ORG",
    "Project": "migrationTest5",
    "Authentication": {
      "Type": "Pat",
      "AccessToken": "$ENV:AZDEVOPS_DEV_PAT"
    }
  },
  "Artefacts": {
    "Path": "%TEMP%\\SystemTests\\export-ado-workitems-single-project",
    "Zip": true
  },
  "Modules": [
    {
      "Name": "WorkItems",
      "Enabled": true,
      "Scopes": [
        {
          "Type": "wiql",
          "Parameters": {
            "query": "SELECT [System.Id] FROM WorkItems WHERE [System.TeamProject] = @project ORDER BY [System.Id]",
            "includeRevisions": true,
            "includeLinks": true,
            "includeAttachments": true
          }
        }
      ]
    }
  ]
}