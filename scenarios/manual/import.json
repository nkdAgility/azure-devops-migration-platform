{
  "MigrationPlatform": {
    "ConfigVersion": "1.0",
    "Policies": {
      "Retries": {
        "Max": 8
      },
      "Throttle": {
        "MaxConcurrency": 4
      },
      "Checkpoints": {
        "Interval": 300
      }
    },
    "Mode": "Import",
    "Target": {
      "Type": "AzureDevOpsServices",
      "Url": "$ENV:AZDEVOPS_SYSTEM_TEST_ORG",
      "Project": "migrationTarget2",
      "Authentication": {
        "Type": "AccessToken",
        "AccessToken": "$ENV:AZDEVOPS_SYSTEM_TEST_PAT"
      }
    },
    "Package": {
      "WorkingDirectory": "%userprofile%\\source\\Tools\\MigrationPlatform\\manual\\import\\",
      "CreatePackage": false,
      "PackagePath": "scenarios\\testdata\\nkdagility-preview-migrationTest5.zip"
    },
    "Modules": {
      "WorkItems": {
        "Enabled": true,
        "Extensions": {
          "Revisions": {
            "Enabled": true
          },
          "Links": {
            "Enabled": true
          },
          "Attachments": {
            "Enabled": true
          },
          "Comments": {
            "Enabled": true
          },
          "EmbeddedImages": {
            "Enabled": true
          },
          "WorkItemResolutionStrategy": {
            "Strategy": "TargetField",
            "FieldName": "nkdScrum.ReflectedWorkItemId"
          }
        }
      }
    }
  }
}