{
  "MigrationPlatform": {
    "ConfigVersion": "2.0",
    "Policies": {
      "Retries": {
        "Max": 8
      },
      "Throttle": {
        "MaxConcurrency": 4
      },
      "Checkpoints": {
        "Interval": 300
      }
    },
    "Mode": "Import",
    "Target": {
      "Type": "Simulated",
      "Url": "https://dev.azure.com/simulated",
      "Project": "SimulatedTarget"
    },
    "Package": {
      "WorkingDirectory": "%DEVOPS_MIGRATION_TEST_STORAGE%",
      "CreatePackage": false
    },
    "Modules": {
      "WorkItems": {
        "Enabled": true,
        "Data": {
          "Revisions": {
            "Enabled": true
          },
          "Comments": {
            "Enabled": true
          },
          "EmbeddedImages": {
            "Enabled": true
          }
        }
      }
    }
  }
}
