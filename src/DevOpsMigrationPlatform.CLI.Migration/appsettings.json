{
  "MigrationPlatform": {
    "ConfigVersion": "1.0",
    "Artefacts": {
      "Path": "%userprofile%\\.DevOpsMigrationPlatform",
      "Zip": false
    },
    "Policies": {
      "Retries": { "Max": 8 },
      "Throttle": { "MaxConcurrency": 4 },
      "Checkpoints": { "Interval": 300 }
    }
  },
  "ControlPlane": {
    "BaseUrl": "http://localhost:5100"
  }
}
