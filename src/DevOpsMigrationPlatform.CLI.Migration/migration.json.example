{
  "configVersion": "1.0",
  "mode": "Export",

  "source": {
    "type": "AzureDevOpsServices",
    "url": "$ENV:SOURCE_ORG_URL",
    "project": "MySourceProject",
    "apiVersion": "7.1",
    "authentication": {
      "Type": "AccessToken",
      "accessToken": "$ENV:SOURCE_PAT"
    }
  },

  "target": {
    "type": "AzureDevOpsServices",
    "url": "$ENV:TARGET_ORG_URL",
    "project": "MyTargetProject",
    "apiVersion": "7.1",
    "authentication": {
      "Type": "AccessToken",
      "accessToken": "$ENV:TARGET_PAT"
    }
  },

  "artefacts": {
    "path": "%USERPROFILE%\\.DevOpsMigrationPlatform\\run-001",
    "zip": false
  },

  "modules": [
    {
      "name": "WorkItems",
      "enabled": true,
      "scopes": [
        {
          "type": "wiql",
          "parameters": {
            "query": "SELECT [System.Id] FROM WorkItems WHERE [System.TeamProject] = @project ORDER BY [System.Id]",
            "includeRevisions": true,
            "includeLinks": true,
            "includeAttachments": true
          }
        }
      ]
    }
  ],

  "policies": {
    "retries": { "max": 8 },
    "throttle": { "maxConcurrency": 4 }
  }
}

}