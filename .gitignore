# Build output
**/bin/
**/obj/
**/output/
scenarios/client/**
storage/**
TestWorkingFolder/**
TestWork/**

# Generated at build time by SchemaGenerator — not committed
src/DevOpsMigrationPlatform.CLI.Migration/migration.schema.json

# Visual Studio / VS Code
.vs/
.vscode/c_cpp_properties.json  # C++ specific settings

# Include shared VS Code configurations for team collaboration:
# .vscode/launch.json       - Debugging configurations (INCLUDED)
# .vscode/tasks.json        - Build tasks (INCLUDED) 
# .vscode/settings.json     - Project-specific settings (INCLUDED)
# .vscode/extensions.json   - Recommended extensions (INCLUDED)
# .vscode/README.md         - Setup documentation (INCLUDED)

# User-specific
*.user
*.suo

# Claude Code local settings (personal overrides, not for sharing)
.claude/settings.local.json

# NuGet
*.nupkg
packages/

# Logs
*.log

# Environment variables and secrets
.env*
*.env

# Development configuration files with credentials
dev-*.json
test-*.json
*-dev.json
local-*.json

# Test results
TestResults/
coverage/

# Build artefacts
artifacts/

# Reqnroll-generated codebehind files (generated before compilation; staged from workspace features/)
**/Features/*.feature.cs
# Reqnroll-staged feature file copies (build artefacts — canonical source is features/ at workspace root)
tests/**/Features/*.feature

# Temporary files
*.tmp
*.swp
.DS_Store
Thumbs.db
test_results.txt

%DEVOPS_MIGRATION_TEST_STORAGE%/**
.output/
.otel-diagnostics/
.otel-diagnostics/stderr.txt
.otel-diagnostics/stdout.txt
.otel-diagnostics/test-run5/stderr.txt
.otel-diagnostics/test-run5/stdout.txt
