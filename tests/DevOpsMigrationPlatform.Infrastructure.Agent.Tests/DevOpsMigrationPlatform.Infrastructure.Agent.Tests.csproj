<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="MSTest.TestAdapter" />
    <PackageReference Include="MSTest.TestFramework" />
    <PackageReference Include="OpenTelemetry" />
    <PackageReference Include="OpenTelemetry.Exporter.InMemory" />
    <PackageReference Include="Reqnroll.MSTest" />
    <PackageReference Include="Moq" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\DevOpsMigrationPlatform.Abstractions\DevOpsMigrationPlatform.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\DevOpsMigrationPlatform.Abstractions.Agent\DevOpsMigrationPlatform.Abstractions.Agent.csproj" />
    <ProjectReference Include="..\..\src\DevOpsMigrationPlatform.Infrastructure\DevOpsMigrationPlatform.Infrastructure.csproj" />
    <ProjectReference Include="..\..\src\DevOpsMigrationPlatform.Infrastructure.Agent\DevOpsMigrationPlatform.Infrastructure.Agent.csproj" />
    <ProjectReference Include="..\..\src\DevOpsMigrationPlatform.Infrastructure.AzureDevOps\DevOpsMigrationPlatform.Infrastructure.AzureDevOps.csproj" />
    <ProjectReference Include="..\..\src\DevOpsMigrationPlatform.Infrastructure.Simulated\DevOpsMigrationPlatform.Infrastructure.Simulated.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Context\JobAgentWorkerDispatchTests.cs" />
  </ItemGroup>

  <ItemGroup>
    <!-- Feature files from the workspace root features/ directory -->
    <ExternalFeatureFiles Include="..\..\features\platform\checkpointing\cursor-resume.feature" />
    <ExternalFeatureFiles Include="..\..\features\platform\checkpointing\import-cursor-resume.feature" />
    <ExternalFeatureFiles Include="..\..\features\platform\checkpointing\resumable-batching-cursor.feature" />
    <ExternalFeatureFiles Include="..\..\features\platform\package-lock\exclusive-package-lock.feature" />
    <ExternalFeatureFiles Include="..\..\features\platform\project-lifecycle\ephemeral-project-lifecycle.feature" />
    <ExternalFeatureFiles Include="..\..\features\platform\validation\package-validation.feature" />
    <ExternalFeatureFiles Include="..\..\features\platform\telemetry\progress-sink.feature" />
    <ExternalFeatureFiles Include="..\..\features\export\work-items\revisions\export-work-item-revisions.feature" />
    <ExternalFeatureFiles Include="..\..\features\export\work-items\links\export-work-item-links.feature" />
    <ExternalFeatureFiles Include="..\..\features\export\work-items\attachments\export-attachments.feature" />
    <ExternalFeatureFiles Include="..\..\features\inventory\work-items\filter-scope-inventory.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\work-items\revisions\streaming-memory-safety.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\work-items\revisions\work-item-resolution-strategies.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\work-items\revisions\rerun-delta-import.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\work-items\revisions\revision-level-progress-tracking.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\field-transform\value-remapping.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\field-transform\copy-field.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\field-transform\exclude-clear.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\field-transform\set-calculate.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\field-transform\tag-transforms.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\field-transform\regex-cleanup.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\field-transform\merge-fields.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\nodetranslation\path-mapping.feature" />
    <ExternalFeatureFiles Include="..\..\features\export\workitems\nodetranslation\path-discovery.feature" />
    <ExternalFeatureFiles Include="..\..\features\export\workitems\nodetranslation\tree-capture.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\nodetranslation\auto-create-nodes.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\nodetranslation\skip-unresolvable.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\nodetranslation\replicate-source-tree.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\nodetranslation\language-override.feature" />
    <ExternalFeatureFiles Include="..\..\features\import\workitems\nodetranslation\iteration-dates.feature" />
    <ExternalFeatureFiles Include="..\..\features\platform\validation\nodetranslation-validation.feature" />
  </ItemGroup>

  <Target Name="PrepareReqnrollFeatureFiles" BeforeTargets="UpdateFeatureFilesInProject">
    <MakeDir Directories="$(ProjectDir)Features" />
    <ItemGroup>
      <_ExpectedFeatureCopies Include="@(ExternalFeatureFiles->'$(ProjectDir)Features\%(Filename)%(Extension)')" />
      <_ExistingFeatureCopies Include="$(ProjectDir)Features\*.feature" />
      <_StaleFeatureCopies Include="@(_ExistingFeatureCopies)" Exclude="@(_ExpectedFeatureCopies)" />
    </ItemGroup>
    <Delete Files="@(_StaleFeatureCopies)" />
    <Copy SourceFiles="@(ExternalFeatureFiles)"
          DestinationFolder="$(ProjectDir)Features"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
