<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="MSTest.TestAdapter" />
    <PackageReference Include="MSTest.TestFramework" />
    <PackageReference Include="Reqnroll.MSTest" />
    <PackageReference Include="Moq" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\DevOpsMigrationPlatform.Abstractions\DevOpsMigrationPlatform.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\DevOpsMigrationPlatform.ControlPlane\DevOpsMigrationPlatform.ControlPlane.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- External feature files to stage into Features/ before Reqnroll code-gen.
         Features/ is a build artefact; the canonical source is features/ at workspace root. -->
    <ExternalFeatureFiles Include="..\..\features\platform\telemetry\job-progress-store.feature" />
    <ExternalFeatureFiles Include="..\..\features\platform\telemetry\progress-controller.feature" />
  </ItemGroup>

  <!-- Copy external feature files into Features/ before Reqnroll codegen so the default
       **\*.feature glob can find them and generate correct adjacent .feature.cs files. -->
  <Target Name="PrepareReqnrollFeatureFiles" BeforeTargets="UpdateFeatureFilesInProject">
    <MakeDir Directories="$(ProjectDir)Features" />
    <Copy SourceFiles="@(ExternalFeatureFiles)"
          DestinationFolder="$(ProjectDir)Features"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
